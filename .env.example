DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
PORT=8000
NODE_ENV=development

# API de busca — Serper (prospecção + enriquecimento)
SERPER_API_KEY=sua_chave_aqui

# Fallback gratuito — SerpApi (100 buscas/mês, sem cartão)
# 1. serpapi.com → Register → confirmar e-mail
# 2. Dashboard → copiar "Your Private API Key" → SERPAPI_KEY
SERPAPI_KEY=

# Segmento de negócio para direcionar o enriquecimento de clientes
# Adicione o tipo de negócio para evitar resultados irrelevantes (ex: pizzaria, farmácia)
# quando o nome do cliente for genérico. Deixe vazio para não filtrar por segmento.
# Exemplos: loja de bicicletas | pet shop | clínica odontológica | academia
ENRICH_SEGMENT=
